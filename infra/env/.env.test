# Project
COMPOSE_PROJECT_NAME=iot

ENV=test

# Service ports exposed to host
INGESTOR_SERVICE_PORT=8081
PROCESSOR_SERVICE_PORT=8082
ALERT_SERVICE_PORT=8083
QUERY_SERVICE_PORT=8084

# Prometheus scrape targets (services run in Docker)
INGESTOR_HOST=ingestor-service
INGESTOR_PORT=8080
PROCESSOR_HOST=processor-service
PROCESSOR_PORT=8080
ALERT_HOST=alert-service
ALERT_PORT=8080
QUERY_HOST=query-service
QUERY_PORT=8080