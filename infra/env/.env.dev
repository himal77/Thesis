COMPOSE_PROJECT_NAME=iot

ENV=dev

# Service ports exposed to host
INGESTOR_SERVICE_PORT=8081
PROCESSOR_SERVICE_PORT=8082
ALERT_SERVICE_PORT=8083
QUERY_SERVICE_PORT=8084

# hosts for prometheus
INGESTOR_HOST=host.docker.internal
INGESTOR_PORT=8081
PROCESSOR_HOST=host.docker.internal
PROCESSOR_PORT=8082
ALERT_HOST=host.docker.internal
ALERT_PORT=8083
QUERY_HOST=host.docker.internal
QUERY_PORT=8084